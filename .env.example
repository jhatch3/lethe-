# =============================================================================
# Lethe — environment variables
# Copy to `.env` and fill in real values. `.env` is gitignored.
# =============================================================================

# --- LLM provider keys (one per agent + the redactor + the drafter) -------
# Agent alpha — GPT-4o (also runs the LLM PHI redactor sweep)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Agent beta — Claude Sonnet 4.5 (also drafts the appeal letter)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Agent gamma — Gemini Flash
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 0G Chain (Galileo testnet) -------------------------------------------
# Docs: https://docs.0g.ai  ·  Faucet: https://faucet.0g.ai/ (if down, see
# src/coordinator/scripts/README.md for community faucet alternatives)
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_CHAIN_ID=16602
# Wallet that signs registry writes. Use a dedicated testnet key — never mainnet.
ZG_PRIVATE_KEY=0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 0G Storage endpoint (used by the storage sidecar to select replication nodes).
ZG_STORAGE_ENDPOINT=https://indexer-storage-testnet-turbo.0g.ai
# When set, every audit's anonymized pattern record is uploaded to 0G Storage
# in parallel with the on-chain PatternRegistry write. The sidecar is the Node
# service in src/coordinator/scripts/ — start it with `npm run storage:0g`.
# Stays a stub when blank (pipeline runs unchanged without it).
LETHE_0G_STORAGE_SIDECAR_URL=http://localhost:8788
# StorageIndex contract on Galileo — closes the loop by recording every
# (billHash → storageRoot) pairing on-chain. Lets the coordinator query
# eth_getLogs for recent roots and pull blobs back as RICHER agent priors
# (full code strings + voter agent names, vs the truncated bytes32 fields
# in PatternRegistry events). Deploy: `python deploy.py --contract StorageIndex`.
LETHE_STORAGE_INDEX_ADDRESS=

# --- Deployed contract addresses ------------------------------------------
# Default values below are the addresses already deployed on Galileo + Sepolia
# for this project. To redeploy your own copies, run `python src/contracts/deploy.py`
# (uses py-solc-x + web3.py, no Foundry required).
BILL_REGISTRY_ADDRESS=0xf6B4C9CA2e8C8a3CE2DE77baa119004d6B51B457
PATTERN_REGISTRY_ADDRESS=0x7665c9692b1c4e6ef90495a584288604b735e23f
# Sepolia mirror — same SHA-256 + verdict, written via KeeperHub Direct Execution.
BILL_REGISTRY_ADDRESS_SEPOLIA=0xf6B4C9CA2e8C8a3CE2DE77baa119004d6B51B457

# --- KeeperHub ------------------------------------------------------------
# Account: https://keeperhub.com  ·  API docs: https://docs.keeperhub.com/api
# MCP docs: https://docs.keeperhub.com/ai-tools
KEEPERHUB_API_KEY=kh_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KEEPERHUB_PROJECT_ID=proj_xxxxxxxxxxxxxxxxxxxxxx
# Optional: a SECOND KeeperHub workflow fires when consensus = "dispute".
# Point at any Sepolia contract exposing `recordDispute(bytes32, uint8, string)`
# (or override the function name). Leave blank to keep the dispute filer stubbed.
LETHE_DISPUTE_REGISTRY_ADDRESS_SEPOLIA=
LETHE_DISPUTE_FUNCTION_NAME=recordDispute
# Optional: a THIRD KeeperHub workflow fires when the user clicks "Send to
# provider" in the dashboard. KH calls `recordAppealSent(billHash, recipientHash)`
# on this Sepolia contract after the email is dispatched. The recipient email
# is keccak-hashed before going on-chain (never plaintext). Leave blank to
# stub — UI flow still works, on-chain attestation just shows "stub".
LETHE_APPEAL_REGISTRY_ADDRESS_SEPOLIA=

# --- Email delivery for appeal letters -----------------------------------
# Provider switch. Stub mode logs the email but doesn't send.
#   resend → modern API service (free tier ~3000/mo, recommended for demos)
#   smtp   → Gmail/Outlook with an app password; stdlib only
#   stub   → log only (default)
LETHE_EMAIL_PROVIDER=stub
LETHE_EMAIL_FROM=Lethe <noreply@lethe.local>
# Resend (https://resend.com/api-keys)
LETHE_RESEND_API_KEY=
# SMTP (e.g. Gmail with app password — see https://support.google.com/accounts/answer/185833)
LETHE_SMTP_HOST=
LETHE_SMTP_PORT=587
LETHE_SMTP_USER=
LETHE_SMTP_PASSWORD=
# Set to "true" to route the Sepolia mirror anchor through KeeperHub's MCP
# server instead of the Direct Execution REST API. The hackathon prize
# specifies "MCP server or CLI" as the integration vector — this flag
# satisfies the strict reading. Falls back to REST if MCP is unreachable.
LETHE_KEEPERHUB_USE_MCP=false
LETHE_KEEPERHUB_MCP_URL=https://app.keeperhub.com/mcp

# --- Coordinator ----------------------------------------------------------
COORDINATOR_PORT=8000
# Comma-separated origins allowed by CORS
CORS_ORIGINS=http://localhost:3000

# --- Frontend (Next.js) ---------------------------------------------------
# Public — exposed to the browser. Must use NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- 0G Compute Network (decentralized inference for agent γ) -------------
# When the endpoint below is set, agent γ runs on 0G Compute instead of
# Google Gemini — answering the strongest 0G judging objection (we use 0G
# Chain AND 0G Compute, not just one). Falls back to Gemini if blank.
#
# IMPORTANT: 0G Compute auth headers are signed against each request body
# and are single-use — there is NO long-lived bearer token. The Lethe
# coordinator handles this via a tiny local sidecar that signs each request
# transparently; LETHE_0G_COMPUTE_TOKEN below can be any non-empty string.
#
# Provisioning (one-time, ~5 min). Requires Node.js 20+ and a Galileo
# testnet wallet (ZG_PRIVATE_KEY above) with at least ~3 OG:
#   cd src/coordinator/scripts
#   npm install
#   npm run provision:0g       # → prints LETHE_0G_COMPUTE_PROVIDER + MODEL
#   npm run headers:0g         # leave running; signs each request on :8787
#
# With the sidecar running, set LETHE_0G_COMPUTE_ENDPOINT to the sidecar URL
# (NOT the raw provider URL) and any string for the token:
LETHE_0G_COMPUTE_ENDPOINT=http://localhost:8787/v1
LETHE_0G_COMPUTE_TOKEN=sidecar-handles-auth
LETHE_0G_COMPUTE_MODEL=GLM-5-FP8
LETHE_0G_COMPUTE_PROVIDER=
# Set to "true" to display "via sidecar" in /api/status. Cosmetic only —
# the coordinator only cares about ENDPOINT being reachable.
LETHE_0G_COMPUTE_SIDECAR=true

# --- Gensyn AXL P2P transport ---------------------------------------------
# When true, every audit broadcasts findings between agents via real AXL
# sidecars (see infra/axl/) and the round-2 reflection runs with peer findings
# as context. Set to false to skip the exchange + reflect stages.
LETHE_AXL_ENABLED=true
# AXL sidecar URLs. Override only if running outside Docker Compose.
LETHE_AXL_ALPHA_URL=http://localhost:9002
LETHE_AXL_BETA_URL=http://localhost:9012
LETHE_AXL_GAMMA_URL=http://localhost:9022