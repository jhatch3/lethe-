# =============================================================================
# Lethe — environment variables
# Copy to `.env` and fill in real values. `.env` is gitignored.
# =============================================================================

# --- LLM provider keys (one per agent) ------------------------------------
# Agent alpha — GPT-4o
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Agent beta — Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Agent gamma — Gemini
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 0G Chain (Galileo testnet) -------------------------------------------
# Faucet & docs: https://docs.0g.ai
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
LETHE_ZG_CHAIN_ID=16602
# Wallet that signs registry writes. Use a dedicated testnet key — never mainnet.
ZG_PRIVATE_KEY=0xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 0G Storage endpoint for the anonymized pattern layer
ZG_STORAGE_ENDPOINT=https://indexer-storage-testnet-turbo.0g.ai

# --- Deployed contract addresses ------------------------------------------
# Set after `forge script` deploys src/contracts
BILL_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
CONSENSUS_VOTE_ADDRESS=0x0000000000000000000000000000000000000000

# --- KeeperHub ------------------------------------------------------------
# Account: https://keeperhub.com
KEEPERHUB_API_KEY=kh_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KEEPERHUB_PROJECT_ID=proj_xxxxxxxxxxxxxxxxxxxxxx

# --- Coordinator ----------------------------------------------------------
COORDINATOR_PORT=8000
# Comma-separated origins allowed by CORS
CORS_ORIGINS=http://localhost:3000

# --- Frontend (Next.js) ---------------------------------------------------
# Public — exposed to the browser. Must use NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_API_URL=http://localhost:8000